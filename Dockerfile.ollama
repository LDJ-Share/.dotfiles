# ═══════════════════════════════════════════════════════════════════════════════
# Ollama Image — Base image for containerized Ollama service
#
# Published to: ghcr.io/ldj-share/.dotfiles/ollama:base
#
# PURPOSE:
#   Provide a base Ollama image that runs the Ollama service.
#   Models are imported into the shared volume on the target machine
#   via the manual import procedure (see MANUAL-MODEL-IMPORT.md).
#
# GPU PASSTHROUGH:
#   GPU support is handled at RUNTIME by the NVIDIA Container Toolkit.
#   This image supports both GPU and CPU-only machines.
#   No GPU-specific directives are in this Dockerfile — see docker-compose.yml
#   (Phase 2) for runtime GPU configuration via deploy.resources.reservations.
#
# BUILD:
#   docker build -f Dockerfile.ollama -t ollama:base .
#
# ─────────────────────────────────────────────────────────────────────────────

# T-1-01 mitigation: pin exact semver — mutable :latest tag enables supply chain substitution
FROM ollama/ollama:0.20.3

# ─────────────────────────────────────────────────────────────────────────────
# Install curl — required for HEALTHCHECK
# curl is absent from the ollama/ollama base image (github.com/ollama/ollama/issues/9781)
# ─────────────────────────────────────────────────────────────────────────────
RUN apt-get update -qq && apt-get install -y -qq curl && rm -rf /var/lib/apt/lists/*

# ─────────────────────────────────────────────────────────────────────────────
# Runtime binding — set for containerized Ollama service
#
# 0.0.0.0 binds to all interfaces so the container is reachable from other
# containers on the Docker bridge network (required for compose integration).
# ─────────────────────────────────────────────────────────────────────────────
ENV OLLAMA_HOST=0.0.0.0:11434

EXPOSE 11434

# HEALTHCHECK uses curl (installed above in the apt step).
# start-period=60s allows ollama to load model weights before probing.
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -sf http://localhost:11434/api/tags || exit 1

# No CMD override — base image CMD is `ollama serve`, which is correct.
# Copy to `.env` only when you want to override the default compose-internal path.
# Leave these unset for the no-edit default workflow: copy template -> docker compose up -> reopen in container.

# Optional reproducible GHCR pinning examples:
# DEV_ENV_IMAGE=ghcr.io/ldj-share/dotfiles/dev-env:<git-sha>
# OLLAMA_IMAGE=ghcr.io/ldj-share/dotfiles/ollama-models:<git-sha>

# Optional Windows host fallback instead of the compose sidecar:
# OLLAMA_HOST=http://10.10.10.10:11434

# Optional offline GPU follow-up after `cuda-prep` and `image-import` restored the bundle:
# uncomment the GPU reservation example in `.devcontainer/docker-compose.yml`

DEV_ENV_IMAGE=dotfiles-dev-env:local
OLLAMA_IMAGE=ollama/ollama:0.20.3
